# Frontend (Vite) — these are public, baked into client bundle
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-public-key

# Edge Function only — never exposed to the client
# Set via: supabase secrets set EBIRD_API_KEY=...
EBIRD_API_KEY=your-ebird-api-token
